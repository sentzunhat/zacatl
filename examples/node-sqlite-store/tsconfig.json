{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@sentzunhat/zacatl/*": ["../../build-src-esm/*"],
      "@sentzunhat/zacatl/third-party": ["../../build-src-esm/third-party/index.d.ts"],
      "@sentzunhat/zacatl/third-party/*": ["../../build-src-esm/third-party/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
