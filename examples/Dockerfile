# Consolidated Dockerfile for all Zacatl examples
# Glibc-based build chain → distroless Node.js 26 Debian 13 runtime
#
# Usage: docker build \
#          --build-arg EXAMPLE=fastify-sqlite-react \
#          --build-arg PORT=8081 \
#          -t zacatl-fastify-sqlite-react .
#
# Build stages:
#   Stage 1: node:26-trixie-slim@sha256:... (Debian 13 glibc builder with native-module tools)
#   Stage 2: node:26-trixie-slim@sha256:... (example install, same glibc ABI)
#   Stage 3a/3b: backend / frontend build
#   Stage 4: gcr.io/distroless/nodejs26-debian13:nonroot@sha256:... (minimal runtime, uid 65532)
#
# Why trixie-slim for the builder?
#   distroless/nodejs26-debian13 is a glibc image. Native modules compiled on
#   musl (alpine) produce .node binaries that fail silently in a glibc runtime.
#   node:26-trixie-slim shares the same Debian 13 glibc ABI, so native modules
#   (sqlite3, pg, mongoose/mongodb) are ABI-compatible in the final image.
#
# Single Dockerfile for all 8+ examples - no duplication

ARG EXAMPLE=fastify-sqlite-react
ARG BACKEND=apps/backend
ARG FRONTEND=apps/frontend
ARG PORT=8080
ARG DATABASE_DRIVER=sqlite3

# ── Stage 1: build zacatl + example (Debian 13 glibc with build tools) ───────
FROM node:26-trixie-slim@sha256:715e55e4b84e4bb0ff48e49b398a848f08e55daed8eb6a0ea1839ae53bc57583 AS builder

ARG DATABASE_DRIVER

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

COPY tsconfig*.json ./
COPY src ./src
COPY scripts ./scripts
# build-scripts-esm is generated by `npm run build` below — do not COPY it;
# it is a local build artifact absent from fresh checkouts (breaks CI).
RUN npm run build && \
    case "${DATABASE_DRIVER}" in \
      mongoose|mongodb|pg|sqlite3) ;; \
      *) echo "Unsupported DATABASE_DRIVER: ${DATABASE_DRIVER}" >&2; exit 1 ;; \
    esac && \
    node -e "const fs=require('node:fs'); const p=JSON.parse(fs.readFileSync('package.json','utf8')); const peers=p.peerDependencies ?? {}; const driver=process.argv[1]; const names=(driver==='sqlite3'||driver==='pg')?['sequelize',driver]:[driver]; p.dependencies=p.dependencies ?? {}; for (const name of names) { const version=peers[name]; if (!version) throw new Error('Missing peer dependency range for '+name); p.dependencies[name]=version; } delete p.peerDependencies; delete p.peerDependenciesMeta; delete p.devDependencies; fs.writeFileSync('package.json', JSON.stringify(p, null, 2)+'\n');" "${DATABASE_DRIVER}" && \
    npm prune --omit=dev --omit=optional && \
    npm install --omit=dev --omit=optional && \
    npm dedupe --omit=dev --omit=optional

# ── Stage 2: install example deps ───────────────────────────────────────────
FROM node:26-trixie-slim@sha256:715e55e4b84e4bb0ff48e49b398a848f08e55daed8eb6a0ea1839ae53bc57583 AS example-install

ARG EXAMPLE

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Materialize built zacatl so the file:../../ symlink resolves at install time
COPY --from=builder /app/package.json             ./package.json
COPY --from=builder /app/build-src-esm            ./build-src-esm
COPY --from=builder /app/build-src-cjs            ./build-src-cjs
COPY --from=builder /app/node_modules             ./node_modules
COPY --from=builder /app/build-scripts-esm        ./build-scripts-esm
COPY --from=builder /app/scripts                  ./scripts
COPY --from=builder /app/src/localization/locales ./src/localization/locales
COPY --from=builder /app/src/eslint               ./src/eslint

COPY examples/${EXAMPLE} ./examples/${EXAMPLE}

WORKDIR /app/examples/${EXAMPLE}
RUN npm install

# ── Stage 3a: build backend ─────────────────────────────────────────────────
FROM example-install AS build-backend

ARG EXAMPLE
ARG BACKEND

WORKDIR /app/examples/${EXAMPLE}
RUN npm run backend:build && npm prune --omit=dev

# Pre-chown the example workdir for distroless nonroot uid 65532 so the
# runtime user can write the SQLite database file into WORKDIR.
RUN chown -R 65532:65532 /app/examples/${EXAMPLE}

# ── Stage 3b: build frontend ────────────────────────────────────────────────
FROM example-install AS build-frontend

ARG EXAMPLE
ARG FRONTEND

WORKDIR /app/examples/${EXAMPLE}
RUN npm run frontend:build

# ── Stage 4: distroless runtime (no shell, no package manager, uid 65532) ───
FROM gcr.io/distroless/nodejs26-debian13:nonroot@sha256:d440510c9ef4ff874b240bb6b855e4de4e797db283e41d8d506da5085a677f26

ARG EXAMPLE
ARG BACKEND
ARG FRONTEND
ARG PORT

ENV NODE_ENV=production
ENV BACKEND_PATH=${BACKEND}
ENV HEALTHCHECK_PATH=/greetings

WORKDIR /app/examples/${EXAMPLE}

# Carry the built zacatl so the @sentzunhat/zacatl symlink resolves at runtime.
# All copies use --chown=65532:65532 matching distroless nonroot uid.
COPY --from=build-backend --chown=65532:65532 /app/package.json             /app/package.json
COPY --from=build-backend --chown=65532:65532 /app/node_modules             /app/node_modules
COPY --from=build-backend --chown=65532:65532 /app/build-src-esm            /app/build-src-esm
COPY --from=build-backend --chown=65532:65532 /app/src/localization/locales /app/src/localization/locales
COPY --from=build-backend --chown=65532:65532 /app/src/eslint               /app/src/eslint

# Example runtime artifacts (pruned node_modules from backend, dist from both)
COPY --from=build-backend  --chown=65532:65532 /app/examples/${EXAMPLE}/node_modules     ./node_modules
COPY --from=build-backend  --chown=65532:65532 /app/examples/${EXAMPLE}/${BACKEND}/dist  ./${BACKEND}/dist
COPY --from=build-frontend --chown=65532:65532 /app/examples/${EXAMPLE}/${FRONTEND}/dist ./${FRONTEND}/dist

EXPOSE ${PORT}

HEALTHCHECK --interval=10s --timeout=5s --start-period=15s --retries=3 CMD ["/nodejs/bin/node", "-e", "const path=process.env.HEALTHCHECK_PATH||'/greetings'; const url=`http://127.0.0.1:${process.env.PORT || '8080'}${path}`; const controller=new AbortController(); const timer=setTimeout(() => controller.abort(), 4000); fetch(url, { signal: controller.signal }).then((r) => { clearTimeout(timer); if (!r.ok) process.exit(1); }).catch(() => process.exit(1));"]

# distroless has no shell — exec form only. ENTRYPOINT is the bundled node
# binary; CMD is the entry script relative to WORKDIR.
# If you override --build-arg BACKEND=custom/path, also override CMD at
# `docker run` time: docker run ... node custom/path/dist/index.js
ENTRYPOINT ["/nodejs/bin/node"]
CMD ["apps/backend/dist/index.js"]
