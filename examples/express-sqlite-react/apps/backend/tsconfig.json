{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "esModuleInterop": true,
    "paths": {
      "@sentzunhat/zacatl/*": [
        "../../../../build-src-esm/*"
      ],
      "@sentzunhat/zacatl/third-party": [
        "../../../../build-src-esm/third-party/index.d.ts"
      ],
      "@sentzunhat/zacatl/third-party/*": [
        "../../../../build-src-esm/third-party/*"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
