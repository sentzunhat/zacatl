{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "paths": {
      "@sentzunhat/zacatl/*": [
        "../../build-src-esm/*"
      ],
      "@sentzunhat/zacatl/third-party": [
        "../../build-src-esm/third-party/index.d.ts"
      ],
      "@sentzunhat/zacatl/third-party/*": [
        "../../build-src-esm/third-party/*"
      ]
    }
  },
  "include": [
    "apps/backend/src/**/*",
    "apps/frontend/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps/backend/dist",
    "apps/frontend/dist",
    "apps/backend/node_modules",
    "apps/frontend/node_modules"
  ]
}
