{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "paths": {
      "@sentzunhat/zacatl": ["../../build-src-esm/index.d.ts"],
      "@sentzunhat/zacatl/*": ["../../build-src-esm/*"],
      "@zacatl": ["../../build-src-esm/index.d.ts"],
      "@zacatl/*": ["../../build-src-esm/*"]
    }
  },
  "include": ["apps/backend/src/**/*", "apps/frontend/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "apps/backend/dist",
    "apps/frontend/dist",
    "apps/backend/node_modules",
    "apps/frontend/node_modules"
  ]
}
