{
  "name": "zacatl-express-postgres-monorepo",
  "version": "1.0.0",
  "description": "Full-stack monorepo: Express + PostgreSQL backend with React frontend",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=26.3.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "backend:dev": "npm --prefix apps/backend run dev",
    "backend:start": "npm --prefix apps/backend run start",
    "backend:build": "npm --prefix apps/backend run build",
    "frontend:dev": "npm --prefix apps/frontend run dev",
    "frontend:build": "npm --prefix apps/frontend run build",
    "frontend:preview": "npm --prefix apps/frontend run preview",
    "dev": "npm run backend:dev & npm run frontend:dev",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "npm run backend:start",
    "clean": "rm -rf apps/*/dist apps/*/node_modules"
  },
  "dependencies": {
    "@sentzunhat/zacatl": "file:../../",
    "pg": "^8.22.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
}
