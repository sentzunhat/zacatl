{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../build-scripts-esm",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    "declaration": false,
    "resolveJsonModule": true,
    "allowJs": false,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": ["dev/parallel-runner.ts"]
}
