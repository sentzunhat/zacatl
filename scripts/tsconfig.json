{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "rootDir": "..",
    "noEmit": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "strict": false,
    "strictNullChecks": true
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules", "build", "coverage"]
}
