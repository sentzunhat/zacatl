{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "outDir": "../build-scripts-cjs",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": true,
    "declaration": false,
    "resolveJsonModule": true,
    "allowJs": false,
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["**/*.ts", "**/*.js"],
  "exclude": [
    "dev/parallel-runner.ts",
    "build/fix-esm.ts",
    "dev/generate-barrels.ts",
    "dev/generate-tsconfig-paths.ts"
  ]
}
